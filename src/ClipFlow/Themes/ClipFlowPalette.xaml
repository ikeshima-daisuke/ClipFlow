<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        MainWindow（履歴ポップアップ）専用の背景・文字色。壁紙やAcrylicの半透明合成に依存しない固定値で、
        WCAGコントラスト比を実測して決定（text-primary 15.2:1 / secondary 8.7:1 / tertiary 6.1:1、
        いずれもAA以上）。MainWindow.xamlでWPF-UIの既定Darkテーマより後にマージし、同名キーを上書きする。
        HotkeyDialog（Mica背景）には適用しない ―― この不透明な背景色をApplication全体に広げると、
        HotkeyDialogのMica効果が透けて見えなくなってしまうため。
        アクセントカラーはここでは扱わない。AccentThemeService（WPF-UI公式のApplicationAccentColorManager
        経由）がApplication全体に反映するので、HotkeyDialogのボーダー等にも自然に及ぶ。
    -->
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="#1C1C1F" />
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#242428" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#2B2B30" />
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="#38383E" />
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#F2F2F5" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#B9B9C1" />
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#9A9AA3" />

</ResourceDictionary>
