<ui:FluentWindow x:Class="ClipFlow.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:ClipFlow.ViewModels"
                 Title="ClipFlow"
                 Icon="pack://application:,,,/Assets/clipflow.ico"
                 Width="400" Height="580"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 Topmost="True"
                 WindowStartupLocation="Manual"
                 WindowBackdropType="Acrylic"
                 ExtendsContentIntoTitleBar="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- 履歴カード用のボタン（既定の枠を消す） -->
        <Style x:Key="CardButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="10,8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ゴースト風の小さなアクションボタン -->
        <Style x:Key="GhostIcon" TargetType="ui:Button">
            <Setter Property="Appearance" Value="Secondary" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- ピンアイコン: ピン留め時はアクセントカラー -->
        <Style x:Key="PinIcon" TargetType="ui:SymbolIcon">
            <Setter Property="Symbol" Value="Pin24" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Pinned}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <Grid Grid.Row="0" Margin="16,16,16,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:SymbolIcon Grid.Column="0" Symbol="ClipboardTextLtr24"
                           FontSize="20" VerticalAlignment="Center"
                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
            <TextBlock Grid.Column="1" Text="ClipFlow" Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

            <ui:Button Grid.Column="2" Style="{StaticResource GhostIcon}"
                       ToolTip="履歴をクリア（ピン留め以外）"
                       Command="{Binding ClearAllCommand}">
                <ui:SymbolIcon Symbol="Delete24" FontSize="16" />
            </ui:Button>
        </Grid>

        <!-- 検索 -->
        <ui:TextBox Grid.Row="1" Margin="16,4,16,10"
                    x:Name="SearchBox"
                    PlaceholderText="履歴を検索…"
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    TextChanged="SearchBox_TextChanged"
                    Icon="{ui:SymbolIcon Search24}" />

        <!-- 履歴一覧 -->
        <Grid Grid.Row="2">
            <ListBox x:Name="HistoryList"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="8,0,8,0"
                     ItemsSource="{Binding Items}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     SelectionChanged="HistoryList_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,2" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Grid>
                                        <Border x:Name="SelBg" CornerRadius="8" Background="Transparent" />
                                        <Border x:Name="AccentBar" Width="3" CornerRadius="2"
                                                HorizontalAlignment="Left" Margin="2,10"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                Visibility="Collapsed" />
                                        <ContentPresenter />
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="SelBg" Property="Background"
                                                    Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                            <Setter TargetName="AccentBar" Property="Visibility" Value="Visible" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ClipItemViewModel}">
                        <Button Style="{StaticResource CardButton}"
                                Command="{Binding DataContext.PasteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- アイコン / サムネイル -->
                                <Border Grid.Column="0" Width="48" Height="48" CornerRadius="6"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                                    <Grid>
                                        <ui:SymbolIcon Symbol="TextField24" FontSize="22"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Visibility="{Binding IsText, Converter={StaticResource BoolToVis}}" />
                                        <Border CornerRadius="6"
                                                Visibility="{Binding IsImage, Converter={StaticResource BoolToVis}}">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- プレビュー -->
                                <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Preview}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="40" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               FontSize="13" />
                                    <TextBlock Text="{Binding TimeAgo}" Margin="0,3,0,0"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               FontSize="11" />
                                </StackPanel>

                                <!-- アクション -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:Button Style="{StaticResource GhostIcon}" ToolTip="ピン留め"
                                               Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                               CommandParameter="{Binding}">
                                        <ui:SymbolIcon Style="{StaticResource PinIcon}" />
                                    </ui:Button>
                                    <ui:Button Style="{StaticResource GhostIcon}" ToolTip="削除"
                                               Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                               CommandParameter="{Binding}">
                                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="15" />
                                    </ui:Button>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 空状態 -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <ui:SymbolIcon Symbol="ClipboardTextLtr24" FontSize="40"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                <TextBlock Text="履歴はまだありません" Margin="0,10,0,0"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <TextBlock Text="コピーすると、ここに溜まります" Margin="0,2,0,0"
                           HorizontalAlignment="Center" FontSize="11"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            </StackPanel>

            <!-- 選択項目の全文プレビュー -->
            <Popup x:Name="PreviewPopup"
                   PlacementTarget="{Binding ElementName=HistoryList}"
                   Placement="Right"
                   HorizontalOffset="8"
                   AllowsTransparency="True"
                   StaysOpen="True"
                   PopupAnimation="Fade">
                <Border Width="320" MaxHeight="500"
                        Padding="14,12"
                        CornerRadius="8"
                        Background="{DynamicResource ApplicationBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.3" />
                    </Border.Effect>
                    <Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      x:Name="PreviewTextScroll">
                            <TextBlock x:Name="PreviewText"
                                       TextWrapping="Wrap"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </ScrollViewer>
                        <Image x:Name="PreviewImage"
                               Stretch="Uniform"
                               MaxHeight="470"
                               Visibility="Collapsed" />
                    </Grid>
                </Border>
            </Popup>
        </Grid>

        <!-- フッター -->
        <Border Grid.Row="3" Padding="16,8"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock FontSize="11"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Text="↑↓ 選択  •  Enter 貼付  •  Ctrl+C コピー  •  Esc 閉じる" />
        </Border>
    </Grid>
</ui:FluentWindow>
